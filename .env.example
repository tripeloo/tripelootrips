# MongoDB — put the DB name in the path before ? e.g. ...mongodb.net/tripeloo?appName=Cluster0
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/tripeloo?retryWrites=true&w=majority
# Strongly recommended if the URI path is empty or ambiguous
MONGODB_DB_NAME=tripeloo
# Optional: log one line to the server console on first connect (dev or always if set to 1)
# MONGODB_LOG_CONNECTION=1

# Public site URL for SEO canonical / Open Graph
NEXT_PUBLIC_SITE_URL=https://tripelootrips.com

# Admin cookie login — set a long random string; required for /admin routes
ADMIN_TOKEN=change-me-to-a-long-secret

# Optional: override tel: for package card call button (default: lib/site-contact.ts → +91 7066444430)
# NEXT_PUBLIC_CALLBACK_PHONE_TEL=tel:+917066444430
